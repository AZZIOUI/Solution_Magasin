@model Solution_Magasin.ViewModels.StockViewModel

@{
    ViewData["Title"] = "Modifier Stock";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-pencil"></i> @ViewData["Title"]</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-info mb-4">
                        <h6><i class="bi bi-info-circle"></i> Informations du produit</h6>
                        <p class="mb-1"><strong>Nom:</strong> @Model.ProductName</p>
                        <p class="mb-0"><strong>Référence:</strong> @Model.Reference</p>
                    </div>

                    <form asp-action="EditStock" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ArticleId" />
                        <input type="hidden" asp-for="ProductName" />
                        <input type="hidden" asp-for="Reference" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Quantity" class="form-label"></label>
                            <input asp-for="Quantity" class="form-control" type="number" min="0" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                            <div class="form-text">Quantité actuelle en stock</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MinQuantity" class="form-label"></label>
                            <input asp-for="MinQuantity" class="form-control" type="number" min="0" />
                            <span asp-validation-for="MinQuantity" class="text-danger"></span>
                            <div class="form-text">Seuil minimum pour alertes de stock</div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Stock" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Retour
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Enregistrer
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
