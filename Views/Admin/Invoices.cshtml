@model List<Solution_Magasin.ViewModels.AdminInvoiceViewModel>
@{
    ViewData["Title"] = "Gestion des Factures";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-file-earmark-text"></i> Gestion des Factures</h2>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Retour au tableau de bord
        </a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <div class="stat-card text-center p-3 bg-light rounded">
                        <h3 class="text-primary">@ViewBag.TotalInvoices</h3>
                        <p class="text-muted mb-0">Total des factures</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card text-center p-3 bg-light rounded">
                        <h3 class="text-success">@ViewBag.TotalAmount.ToString("N2") DH</h3>
                        <p class="text-muted mb-0">Montant total</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card text-center p-3 bg-light rounded">
                        <h3 class="text-info">@(ViewBag.TotalInvoices > 0 ? (ViewBag.TotalAmount / ViewBag.TotalInvoices).ToString("N2") : "0.00") DH</h3>
                        <p class="text-muted mb-0">Panier moyen</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="invoicesTable">
                        <thead>
                            <tr>
                                <th>N° Facture</th>
                                <th>Date Facture</th>
                                <th>Date Commande</th>
                                <th>Client</th>
                                <th class="text-end">Montant TTC</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var invoice in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@invoice.CodeFacture</strong>
                                    </td>
                                    <td>@invoice.DateFacture?.ToString("dd/MM/yyyy")</td>
                                    <td>@invoice.OrderDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <div>
                                            <strong>@invoice.ClientName</strong><br>
                                            <small class="text-muted">@invoice.ClientEmail</small>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <strong class="text-success">@invoice.MontantTotal?.ToString("N2") DH</strong>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-controller="Client" asp-action="ViewInvoice" 
                                               asp-route-orderId="@invoice.IdVente" 
                                               class="btn btn-outline-success" 
                                               title="Voir la facture"
                                               target="_blank">
                                                <i class="bi bi-file-earmark-pdf"></i>
                                            </a>
                                            <a asp-action="SaleDetails" asp-route-id="@invoice.IdVente" 
                                               class="btn btn-outline-primary" 
                                               title="Voir la commande">
                                                <i class="bi bi-receipt"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-active">
                                <th colspan="4" class="text-end">Total général :</th>
                                <th class="text-end">@Model.Sum(i => i.MontantTotal ?? 0).ToString("N2") DH</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-file-earmark-text" style="font-size: 4rem; color: #ccc;"></i>
            <h3 class="mt-3">Aucune facture générée</h3>
            <p class="text-muted">Les factures apparaîtront ici aprčs les commandes des clients.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#invoicesTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/fr-FR.json'
                },
                order: [[1, 'desc']], // Sort by invoice date (newest first)
                pageLength: 25,
                footerCallback: function (row, data, start, end, display) {
                    var api = this.api();
                    
                    // Total over current page
                    var pageTotal = api
                        .column(4, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            var value = parseFloat($(b).text().replace(/[^\d.-]/g, ''));
                            return a + (isNaN(value) ? 0 : value);
                        }, 0);
                    
                    // Update footer
                    $(api.column(4).footer()).html(
                        pageTotal.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') + ' DH'
                    );
                }
            });
        });
    </script>
}
