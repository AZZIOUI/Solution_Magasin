@model List<Solution_Magasin.ViewModels.AdminReturnViewModel>
@{
    ViewData["Title"] = "Gestion des Retours";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-arrow-return-left"></i> Gestion des Retours</h2>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Retour au tableau de bord
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <div class="stat-card text-center p-3 bg-light rounded">
                        <h3 class="text-primary">@Model.Count</h3>
                        <p class="text-muted mb-0">Total des retours</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card text-center p-3 bg-light rounded">
                        <h3 class="text-warning">@Model.Count(r => r.Status == "En cours de traitement")</h3>
                        <p class="text-muted mb-0">En traitement</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="returnsTable">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Commande</th>
                                <th>Client</th>
                                <th>Produit</th>
                                <th>Motif</th>
                                <th>Statut</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var retour in Model)
                            {
                                <tr>
                                    <td>@retour.DateRetour?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <strong>@retour.OrderNumber</strong>
                                    </td>
                                    <td>
                                        <div>
                                            <strong>@retour.ClientName</strong><br>
                                            <small class="text-muted">@retour.ClientEmail</small>
                                        </div>
                                    </td>
                                    <td>
                                        <div>
                                            @retour.ProductName<br>
                                            <small class="text-muted">Réf: @retour.ProductReference</small>
                                        </div>
                                    </td>
                                    <td>
                                        <small>@(retour.Motif?.Length > 50 ? retour.Motif.Substring(0, 50) + "..." : retour.Motif)</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-warning text-dark">@retour.Status</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="ReturnDetails" asp-route-id="@retour.IdRetour" 
                                               class="btn btn-outline-primary" title="Détails">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <form asp-action="DeleteReturn" method="post" class="d-inline" 
                                                  onsubmit="return confirm('Ętes-vous sűr de vouloir supprimer ce retour ?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@retour.IdRetour" />
                                                <button type="submit" class="btn btn-outline-danger" title="Supprimer">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
            <h3 class="mt-3">Aucun retour enregistré</h3>
            <p class="text-muted">Les demandes de retour apparaîtront ici.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#returnsTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/fr-FR.json'
                },
                order: [[0, 'desc']],
                pageLength: 25
            });

            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 5000);
        });
    </script>
}
