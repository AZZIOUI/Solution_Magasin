@model List<Solution_Magasin.ViewModels.AdminReviewViewModel>
@{
    ViewData["Title"] = "Gestion des Avis";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-star"></i> Gestion des Avis Produits</h2>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Retour au tableau de bord
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <div class="stat-card text-center p-3 bg-light rounded">
                        <h3 class="text-primary">@ViewBag.TotalReviews</h3>
                        <p class="text-muted mb-0">Total des avis</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card text-center p-3 bg-light rounded">
                        <h3 class="text-warning">@ViewBag.AverageRating.ToString("F1")</h3>
                        <p class="text-muted mb-0">Note moyenne</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card text-center p-3 bg-light rounded">
                        <h3 class="text-success">@Model.Count(r => r.Rating >= 4)</h3>
                        <p class="text-muted mb-0">Avis positifs (?4?)</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card text-center p-3 bg-light rounded">
                        <h3 class="text-danger">@Model.Count(r => r.Rating <= 2)</h3>
                        <p class="text-muted mb-0">Avis négatifs (?2?)</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="reviewsTable">
                        <thead>
                            <tr>
                                <th>Produit</th>
                                <th>Client</th>
                                <th>Note</th>
                                <th>Commentaire</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var review in Model)
                            {
                                <tr id="review-@review.IdReview">
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(review.ProductImage))
                                            {
                                                <img src="@review.ProductImage" alt="@review.ProductName" 
                                                     class="me-2 rounded" style="width: 50px; height: 50px; object-fit: cover;">
                                            }
                                            <div>
                                                <strong>@review.ProductName</strong><br>
                                                <small class="text-muted">Réf: @review.ProductReference</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div>
                                            <strong>@review.ClientName</strong><br>
                                            <small class="text-muted">@review.ClientEmail</small>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="rating-display">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= review.Rating)
                                                {
                                                    <i class="bi bi-star-fill text-warning"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-star text-muted"></i>
                                                }
                                            }
                                            <span class="ms-1">(@review.Rating/5)</span>
                                        </div>
                                    </td>
                                    <td>
                                        <small>@(review.Comment?.Length > 80 ? review.Comment.Substring(0, 80) + "..." : review.Comment)</small>
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-outline-danger delete-review" 
                                                data-review-id="@review.IdReview"
                                                title="Supprimer">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-chat-left-text" style="font-size: 4rem; color: #ccc;"></i>
            <h3 class="mt-3">Aucun avis enregistré</h3>
            <p class="text-muted">Les avis des clients apparaîtront ici.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#reviewsTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/fr-FR.json'
                },
                order: [[2, 'asc']], // Sort by rating (lowest first for moderation)
                pageLength: 25
            });

            // Delete review
            $('.delete-review').click(function() {
                var reviewId = $(this).data('review-id');
                var $row = $('#review-' + reviewId);
                
                if (confirm('Ętes-vous sűr de vouloir supprimer cet avis ? Cette action est irréversible.')) {
                    $.post('@Url.Action("DeleteReview", "Admin")', { 
                        id: reviewId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    })
                    .done(function(response) {
                        if (response.success) {
                            $row.fadeOut(400, function() {
                                $('#reviewsTable').DataTable().row($row).remove().draw();
                            });
                            
                            // Show success message
                            var alertHtml = '<div class="alert alert-success alert-dismissible fade show" role="alert">' +
                                           response.message +
                                           '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                                           '</div>';
                            $('.container-fluid').prepend(alertHtml);
                            
                            setTimeout(function() {
                                $('.alert').fadeOut('slow');
                            }, 3000);
                        } else {
                            alert(response.message);
                        }
                    })
                    .fail(function() {
                        alert('Une erreur est survenue lors de la suppression');
                    });
                }
            });

            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 5000);
        });
    </script>
    
    <style>
        .rating-display {
            font-size: 1.1rem;
        }
    </style>
}

<!-- Hidden CSRF token for AJAX requests -->
@Html.AntiForgeryToken()
