@model IEnumerable<Solution_Magasin.ViewModels.SalesViewModel>

@{
    ViewData["Title"] = "Historique des Ventes";
}

<div class="container-fluid mt-4">
    <h1 class="mb-4"><i class="bi bi-bag-check"></i> @ViewData["Title"]</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-striped" id="salesTable">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Date</th>
                            <th>Client</th>
                            <th>Nb. Articles</th>
                            <th>Total</th>
                            <th>Statut</th>
                            <th>Paiement</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sale in Model)
                        {
                            var statusClass = sale.Status switch
                            {
                                "Livrée" => "success",
                                "En cours" => "warning",
                                "Annulée" => "danger",
                                _ => "secondary"
                            };

                            <tr>
                                <td><strong>#@sale.Id</strong></td>
                                <td>@(sale.SaleDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                <td>@sale.ClientName</td>
                                <td>
                                    <span class="badge bg-info">@sale.ItemCount</span>
                                </td>
                                <td><strong>@sale.Total.ToString("C2")</strong></td>
                                <td>
                                    <span class="badge bg-@statusClass">@sale.Status</span>
                                </td>
                                <td>@(sale.PaymentMethod ?? "N/A")</td>
                                <td>
                                    <a asp-action="SaleDetails" asp-route-id="@sale.Id" 
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> Détails
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-secondary">
                            <th colspan="4" class="text-end">Total Général:</th>
                            <th colspan="4">@Model.Sum(s => s.Total).ToString("C2")</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#salesTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/fr-FR.json'
                },
                order: [[1, 'desc']], // Trier par date décroissante
                pageLength: 25
            });
        });
    </script>
}
