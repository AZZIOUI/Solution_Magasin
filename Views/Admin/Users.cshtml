@model List<Solution_Magasin.ViewModels.UserListViewModel>
@{
    ViewData["Title"] = "Gestion des Utilisateurs";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="CreateEmployee" class="btn btn-primary">
            <i class="bi bi-person-plus"></i> Créer un Employé
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <!-- Filtres -->
            <div class="row mb-3">
                <div class="col-md-4">
                    <input type="text" id="searchInput" class="form-control" placeholder="?? Rechercher par email ou nom..." />
                </div>
                <div class="col-md-3">
                    <select id="filterUserType" class="form-select">
                        <option value="">Tous les types</option>
                        <option value="Client">Clients</option>
                        <option value="Employe">Employés</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select id="filterStatus" class="form-select">
                        <option value="">Tous les statuts</option>
                        <option value="true">Actifs</option>
                        <option value="false">Inactifs</option>
                    </select>
                </div>
            </div>

            <!-- Table -->
            <div class="table-responsive">
                <table class="table table-hover" id="usersTable">
                    <thead class="table-light">
                        <tr>
                            <th>Email</th>
                            <th>Nom Complet</th>
                            <th>Type</th>
                            <th>Rôle(s)</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    Aucun utilisateur trouvé
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>
                                        <i class="bi bi-envelope"></i> @user.Email
                                    </td>
                                    <td>@user.FirstName @user.LastName</td>
                                    <td>
                                        @if (user.UserType == "Client")
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-person"></i> Client
                                            </span>
                                        }
                                        else if (user.UserType == "Employe")
                                        {
                                            <span class="badge bg-primary">
                                                <i class="bi bi-briefcase"></i> Employé
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @foreach (var role in user.Roles.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            var badgeClass = role.Trim() switch
                                            {
                                                "Administrateur" => "bg-danger",
                                                "ResponsableAchat" => "bg-warning text-dark",
                                                "Magasinier" => "bg-info text-dark",
                                                "Client" => "bg-success",
                                                _ => "bg-secondary"
                                            };
                                            <span class="badge @badgeClass me-1">@role.Trim()</span>
                                        }
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle"></i> Actif
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-x-circle"></i> Inactif
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <button type="button" class="btn btn-outline-primary" title="Détails">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button type="button" class="btn btn-outline-warning" title="Modifier">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            @if (user.IsActive)
                                            {
                                                <button type="button" class="btn btn-outline-danger" title="Désactiver">
                                                    <i class="bi bi-lock"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-outline-success" title="Activer">
                                                    <i class="bi bi-unlock"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="mt-3">
                    <small class="text-muted">
                        Total: <strong>@Model.Count</strong> utilisateur(s)
                    </small>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Retour au tableau de bord
        </a>
    </div>
</div>

@section Scripts {
    <script>
        // Recherche et filtrage côté client
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('searchInput');
            const filterUserType = document.getElementById('filterUserType');
            const filterStatus = document.getElementById('filterStatus');
            const table = document.getElementById('usersTable');
            const rows = table.querySelectorAll('tbody tr');

            function filterTable() {
                const searchTerm = searchInput.value.toLowerCase();
                const userTypeFilter = filterUserType.value;
                const statusFilter = filterStatus.value;

                rows.forEach(row => {
                    if (row.cells.length === 1) return; // Skip "no data" row

                    const email = row.cells[0].textContent.toLowerCase();
                    const name = row.cells[1].textContent.toLowerCase();
                    const userType = row.cells[2].textContent.toLowerCase();
                    const isActive = row.cells[4].textContent.includes('Actif');

                    let show = true;

                    // Search filter
                    if (searchTerm && !email.includes(searchTerm) && !name.includes(searchTerm)) {
                        show = false;
                    }

                    // User type filter
                    if (userTypeFilter && !userType.includes(userTypeFilter.toLowerCase())) {
                        show = false;
                    }

                    // Status filter
                    if (statusFilter) {
                        const filterActive = statusFilter === 'true';
                        if (isActive !== filterActive) {
                            show = false;
                        }
                    }

                    row.style.display = show ? '' : 'none';
                });
            }

            searchInput.addEventListener('input', filterTable);
            filterUserType.addEventListener('change', filterTable);
            filterStatus.addEventListener('change', filterTable);
        });
    </script>
}
