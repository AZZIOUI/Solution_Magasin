@model Solution_Magasin.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Mon Panier";
}

<div class="container py-4">
    <h2 class="mb-4"><i class="bi bi-cart"></i> Mon Panier</h2>

    @if (!Model.Items.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-cart-x" style="font-size: 4rem; color: #ccc;"></i>
                <h4 class="mt-3">Votre panier est vide</h4>
                <p class="text-muted">Découvrez nos produits et commencez vos achats</p>
                <a asp-controller="Visitor" asp-action="Catalog" class="btn btn-primary">
                    <i class="bi bi-grid"></i> Parcourir le catalogue
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Articles (@Model.TotalItems)</h5>
                    </div>
                    <div class="card-body">
                        @foreach (var item in Model.Items)
                        {
                            <div class="cart-item row align-items-center mb-3 pb-3 border-bottom">
                                <div class="col-md-2">
                                    @if (!string.IsNullOrEmpty(item.ImagePath))
                                    {
                                        <img src="~/@item.ImagePath" class="img-fluid rounded" alt="@item.ProductName">
                                    }
                                    else
                                    {
                                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="height: 80px;">
                                            <i class="bi bi-image"></i>
                                        </div>
                                    }
                                </div>
                                <div class="col-md-4">
                                    <h6>@item.ProductName</h6>
                                    <small class="text-muted">Réf: @item.ProductReference</small>
                                    <p class="text-primary mb-0">@item.UnitPrice.ToString("N2") DH</p>
                                </div>
                                <div class="col-md-3">
                                    <div class="input-group">
                                        <button class="btn btn-outline-secondary btn-sm" type="button" onclick="updateQuantity(@item.IdArticle, -1)">
                                            <i class="bi bi-dash"></i>
                                        </button>
                                        <input type="number" class="form-control form-control-sm text-center quantity-input" 
                                               id="quantity-@item.IdArticle" 
                                               value="@item.Quantity" 
                                               min="1" 
                                               max="@item.MaxQuantity" 
                                               readonly>
                                        <button class="btn btn-outline-secondary btn-sm" type="button" onclick="updateQuantity(@item.IdArticle, 1)">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </div>
                                    <small class="text-muted">Max: @item.MaxQuantity</small>
                                </div>
                                <div class="col-md-2 text-end">
                                    <strong class="text-primary">@item.TotalPrice.ToString("N2") DH</strong>
                                </div>
                                <div class="col-md-1 text-end">
                                    <button class="btn btn-link text-danger" onclick="removeItem(@item.IdArticle)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <a asp-controller="Visitor" asp-action="Catalog" class="btn btn-outline-primary">
                        <i class="bi bi-arrow-left"></i> Continuer mes achats
                    </a>
                    <button class="btn btn-outline-danger" onclick="clearCart()">
                        <i class="bi bi-trash"></i> Vider le panier
                    </button>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm sticky-top" style="top: 20px;">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Récapitulatif</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Sous-total</span>
                            <strong id="subtotal">@Model.Subtotal.ToString("N2") DH</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Frais de livraison</span>
                            <strong>@Model.ShippingCost.ToString("N2") DH</strong>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="h5">Total</span>
                            <strong class="h5 text-primary" id="total">@Model.Total.ToString("N2") DH</strong>
                        </div>
                        <a asp-action="Checkout" class="btn btn-primary btn-lg w-100">
                            <i class="bi bi-bag-check"></i> Passer la commande
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function updateQuantity(productId, change) {
            const input = document.getElementById(`quantity-${productId}`);
            let newQuantity = parseInt(input.value) + change;
            const max = parseInt(input.max);
            
            if (newQuantity < 1) newQuantity = 1;
            if (newQuantity > max) {
                alert(`Quantité maximale disponible: ${max}`);
                return;
            }
            
            input.value = newQuantity;
            updateCartItem(productId, newQuantity);
        }

        function updateCartItem(productId, quantity) {
            fetch('@Url.Action("UpdateCartItem")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `productId=${productId}&quantity=${quantity}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('subtotal').textContent = data.subtotal.toFixed(2) + ' DH';
                    document.getElementById('total').textContent = data.total.toFixed(2) + ' DH';
                    location.reload(); // Reload to update item totals
                } else {
                    alert(data.message);
                }
            });
        }

        function removeItem(productId) {
            if (!confirm('Voulez-vous vraiment retirer cet article du panier ?')) return;
            
            fetch('@Url.Action("RemoveFromCart")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `productId=${productId}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message);
                }
            });
        }

        function clearCart() {
            if (!confirm('Voulez-vous vraiment vider votre panier ?')) return;
            
            fetch('@Url.Action("ClearCart")', {
                method: 'POST'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                }
            });
        }
    </script>
}
