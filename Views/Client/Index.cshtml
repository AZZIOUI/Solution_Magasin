@{
    ViewData["Title"] = "Espace Client";
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-4">
                <i class="bi bi-person-circle"></i> Bienvenue, @ViewBag.UserName
            </h1>
            <p class="lead">Gérez vos commandes, votre profil et bien plus encore</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Orders Card -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 hover-card">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="bi bi-bag-check display-4 text-primary"></i>
                    </div>
                    <h5 class="card-title">Mes Commandes</h5>
                    <p class="card-text text-muted">Consultez l'historique de vos commandes</p>
                    <a asp-action="MyOrders" class="btn btn-primary stretched-link">
                        Voir mes commandes
                    </a>
                    @if (ViewBag.OrdersCount != null && ViewBag.OrdersCount > 0)
                    {
                        <div class="mt-2">
                            <span class="badge bg-primary">@ViewBag.OrdersCount commande(s)</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Returns Card -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 hover-card">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="bi bi-arrow-return-left display-4 text-warning"></i>
                    </div>
                    <h5 class="card-title">Mes Retours</h5>
                    <p class="card-text text-muted">Gérez vos demandes de retour</p>
                    <a asp-action="MyReturns" class="btn btn-warning stretched-link">
                        Voir mes retours
                    </a>
                </div>
            </div>
        </div>

        <!-- Reviews Card -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 hover-card">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="bi bi-star display-4 text-success"></i>
                    </div>
                    <h5 class="card-title">Mes Avis</h5>
                    <p class="card-text text-muted">Consultez vos avis produits</p>
                    <a asp-action="MyReviews" class="btn btn-success stretched-link">
                        Voir mes avis
                    </a>
                </div>
            </div>
        </div>

        <!-- Profile Card -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 hover-card">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="bi bi-person display-4 text-info"></i>
                    </div>
                    <h5 class="card-title">Mon Profil</h5>
                    <p class="card-text text-muted">Modifiez vos informations personnelles</p>
                    <a asp-action="Profile" class="btn btn-info stretched-link">
                        Gérer mon profil
                    </a>
                </div>
            </div>
        </div>

        <!-- Shopping Cart Card -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 hover-card">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="bi bi-cart display-4 text-secondary"></i>
                    </div>
                    <h5 class="card-title">Mon Panier</h5>
                    <p class="card-text text-muted">Consultez votre panier d'achat</p>
                    <a asp-action="Cart" class="btn btn-secondary stretched-link">
                        Voir mon panier
                    </a>
                </div>
            </div>
        </div>

        <!-- Browse Products Card -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 hover-card">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="bi bi-shop display-4 text-primary"></i>
                    </div>
                    <h5 class="card-title">Catalogue</h5>
                    <p class="card-text text-muted">Découvrez nos produits</p>
                    <a asp-controller="Visitor" asp-action="Catalog" class="btn btn-outline-primary stretched-link">
                        Parcourir le catalogue
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>
