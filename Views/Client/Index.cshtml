@{
    ViewData["Title"] = "Espace Client";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">@ViewData["Title"]</h1>
            <div class="alert alert-success" role="alert">
                <h4 class="alert-heading">Bienvenue dans votre espace client !</h4>
                <p>Vous Ítes connectť en tant que <strong>@User.Identity?.Name</strong></p>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Mes Commandes</h5>
                    <p class="card-text">Consultez l'historique de vos commandes et suivez leur statut.</p>
                    <a asp-action="MyOrders" class="btn btn-primary">Voir mes commandes</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Mon Profil</h5>
                    <p class="card-text">Gťrez vos informations personnelles et prťfťrences.</p>
                    <a asp-action="Profile" class="btn btn-primary">Voir mon profil</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Catalogue</h5>
                    <p class="card-text">Parcourez notre catalogue de produits.</p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Voir le catalogue</a>
                </div>
            </div>
        </div>
    </div>
</div>
