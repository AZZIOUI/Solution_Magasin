@model Solution_Magasin.ViewModels.OrderHistoryViewModel
@{
    ViewData["Title"] = "Mes Commandes";
}

<div class="container py-4">
    <h2 class="mb-4"><i class="bi bi-bag"></i> Mes Commandes</h2>

    @if (!Model.Orders.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-bag-x" style="font-size: 4rem; color: #ccc;"></i>
                <h4 class="mt-3">Aucune commande</h4>
                <p class="text-muted">Vous n'avez pas encore passé de commande</p>
                <a asp-controller="Visitor" asp-action="Catalog" class="btn btn-primary">
                    <i class="bi bi-grid"></i> Découvrir nos produits
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var order in Model.Orders)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white">
                            <div class="row align-items-center">
                                <div class="col-md-6">
                                    <h5 class="mb-0">
                                        Commande #@order.IdVente
                                        <span class="badge @(order.PaymentStatus == "Payé" ? "bg-success" : "bg-warning")">
                                            @order.PaymentStatus
                                        </span>
                                    </h5>
                                    <small class="text-muted">@order.DateVente?.ToString("dd/MM/yyyy ŕ HH:mm")</small>
                                </div>
                                <div class="col-md-6 text-md-end">
                                    <strong class="text-primary">@order.TotalAmount?.ToString("N2") DH</strong>
                                    <p class="mb-0 text-muted small">@order.ItemCount article(s)</p>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                @foreach (var item in order.Items.Take(3))
                                {
                                    <div class="col-md-4">
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(item.ImagePath))
                                            {
                                                <img src="~/@item.ImagePath" alt="@item.ProductName" class="me-2 rounded" style="width: 60px; height: 60px; object-fit: cover;">
                                            }
                                            else
                                            {
                                                <div class="bg-secondary text-white d-flex align-items-center justify-content-center me-2 rounded" style="width: 60px; height: 60px;">
                                                    <i class="bi bi-image"></i>
                                                </div>
                                            }
                                            <div>
                                                <p class="mb-0 fw-bold">@item.ProductName</p>
                                                <small class="text-muted">Qté: @item.Quantity</small>
                                            </div>
                                        </div>
                                    </div>
                                }
                                @if (order.Items.Count > 3)
                                {
                                    <div class="col-md-12">
                                        <small class="text-muted">+ @(order.Items.Count - 3) autre(s) article(s)</small>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0">
                            <a asp-action="OrderDetails" asp-route-id="@order.IdVente" class="btn btn-outline-primary">
                                <i class="bi bi-eye"></i> Voir les détails
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
