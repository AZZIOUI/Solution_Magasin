@model Solution_Magasin.ViewModels.OrderHistoryViewModel
@{
    ViewData["Title"] = "Mes Commandes";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-bag-check"></i> Mes Commandes</h2>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-house"></i> Retour ŕ l'accueil
        </a>
    </div>

    @if (Model.Orders.Any())
    {
        <div class="row">
            @foreach (var order in Model.Orders)
            {
                <div class="col-12 mb-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white">
                            <div class="row align-items-center">
                                <div class="col-md-3">
                                    <small class="text-muted">COMMANDE</small>
                                    <h5 class="mb-0">#@order.IdVente</h5>
                                </div>
                                <div class="col-md-3">
                                    <small class="text-muted">DATE</small>
                                    <div>@order.DateVente?.ToString("dd/MM/yyyy")</div>
                                </div>
                                <div class="col-md-3">
                                    <small class="text-muted">TOTAL</small>
                                    <div class="fw-bold text-primary">@order.TotalAmount?.ToString("N2") DH</div>
                                </div>
                                <div class="col-md-3 text-end">
                                    <span class="badge @(order.PaymentStatus == "Payé" ? "bg-success" : "bg-warning")">
                                        @order.PaymentStatus
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-lg-8">
                                    <h6 class="mb-3">Articles (@order.ItemCount)</h6>
                                    <div class="row g-3">
                                        @foreach (var item in order.Items.Take(4))
                                        {
                                            <div class="col-md-6">
                                                <div class="d-flex align-items-center">
                                                    @if (!string.IsNullOrEmpty(item.ImagePath))
                                                    {
                                                        <img src="@item.ImagePath" alt="@item.ProductName" 
                                                             class="me-2 rounded" style="width: 50px; height: 50px; object-fit: cover;">
                                                    }
                                                    else
                                                    {
                                                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center me-2 rounded" 
                                                             style="width: 50px; height: 50px;">
                                                            <i class="bi bi-image"></i>
                                                        </div>
                                                    }
                                                    <div>
                                                        <div class="small fw-bold">@item.ProductName</div>
                                                        <div class="text-muted small">Qté: @item.Quantity</div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    @if (order.ItemCount > 4)
                                    {
                                        <div class="text-muted small mt-2">
                                            +@(order.ItemCount - 4) autre(s) article(s)
                                        </div>
                                    }
                                </div>
                                <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                                    <div class="d-flex flex-column gap-2">
                                        <a asp-action="OrderDetails" asp-route-id="@order.IdVente" 
                                           class="btn btn-primary">
                                            <i class="bi bi-eye"></i> Voir les détails
                                        </a>
                                        <a asp-action="ViewInvoice" asp-route-orderId="@order.IdVente" 
                                           class="btn btn-success" target="_blank">
                                            <i class="bi bi-file-earmark-pdf"></i> Facture
                                        </a>
                                        <a asp-action="MyReturns" class="btn btn-outline-warning">
                                            <i class="bi bi-arrow-return-left"></i> Retours
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size: 5rem; color: #dee2e6;"></i>
            <h3 class="mt-4">Aucune commande</h3>
            <p class="text-muted">Vous n'avez pas encore passé de commande.</p>
            <a asp-controller="Visitor" asp-action="Catalog" class="btn btn-primary mt-3">
                <i class="bi bi-shop"></i> Découvrir nos produits
            </a>
        </div>
    }
</div>
