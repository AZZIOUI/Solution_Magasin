@model Solution_Magasin.ViewModels.ReturnHistoryViewModel
@{
    ViewData["Title"] = "Mes Retours";
}

<div class="container my-5">
    <h1 class="mb-4"><i class="bi bi-arrow-return-left"></i> Mes Retours</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Returns.Any())
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title">Statistiques</h5>
                <p class="mb-0"><strong>Total des retours :</strong> @Model.TotalReturns</p>
            </div>
        </div>

        <div class="row">
            @foreach (var retour in Model.Returns)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex">
                                <div class="me-3">
                                    @if (!string.IsNullOrEmpty(retour.ProductImage))
                                    {
                                        <img src="@retour.ProductImage" alt="@retour.ProductName" 
                                             class="img-thumbnail" style="width: 100px; height: 100px; object-fit: cover;">
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center" 
                                             style="width: 100px; height: 100px;">
                                            <i class="bi bi-image" style="font-size: 2rem;"></i>
                                        </div>
                                    }
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="card-title mb-1">@retour.ProductName</h5>
                                    <p class="text-muted small mb-2">Réf: @retour.ProductReference</p>
                                    <p class="mb-1"><strong>Commande :</strong> @retour.OrderNumber</p>
                                    <p class="mb-1"><strong>Date de retour :</strong> @retour.DateRetour?.ToString("dd/MM/yyyy")</p>
                                    <p class="mb-1"><strong>Prix :</strong> @retour.ProductPrice?.ToString("F2") DH</p>
                                    <span class="badge bg-warning text-dark">@retour.Status</span>
                                </div>
                            </div>
                            
                            <hr>
                            
                            <div class="mb-3">
                                <strong>Motif du retour :</strong>
                                <p class="mb-0">@retour.Motif</p>
                            </div>
                            
                            <div class="d-flex justify-content-end">
                                <a asp-action="ReturnDetails" asp-route-id="@retour.IdRetour" 
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> Voir les détails
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
            <h3 class="mt-3">Aucun retour pour le moment</h3>
            <p class="text-muted">Vous n'avez effectué aucun retour de produit.</p>
            <a asp-action="MyOrders" class="btn btn-primary mt-3">
                <i class="bi bi-bag-check"></i> Voir mes commandes
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Auto-dismiss alerts after 5 seconds
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}
