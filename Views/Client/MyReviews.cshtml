@model Solution_Magasin.ViewModels.ReviewHistoryViewModel
@{
    ViewData["Title"] = "Mes Avis";
}

<div class="container my-5">
    <h1 class="mb-4"><i class="bi bi-star"></i> Mes Avis</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Reviews.Any())
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <h5 class="card-title">Statistiques</h5>
                        <p class="mb-0"><strong>Total des avis :</strong> @Model.TotalReviews</p>
                    </div>
                    <div class="col-md-4">
                        <h5 class="card-title">Note moyenne</h5>
                        <div class="d-flex align-items-center">
                            <span class="h4 mb-0 me-2">@Model.AverageRating.ToString("F1")</span>
                            <div>
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Model.AverageRating)
                                    {
                                        <i class="bi bi-star-fill text-warning"></i>
                                    }
                                    else if (i - Model.AverageRating < 1)
                                    {
                                        <i class="bi bi-star-half text-warning"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star text-warning"></i>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            @foreach (var review in Model.Reviews)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex mb-3">
                                <div class="me-3">
                                    @if (!string.IsNullOrEmpty(review.ProductImage))
                                    {
                                        <img src="@review.ProductImage" alt="@review.ProductName" 
                                             class="img-thumbnail" style="width: 80px; height: 80px; object-fit: cover;">
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center" 
                                             style="width: 80px; height: 80px;">
                                            <i class="bi bi-image" style="font-size: 1.5rem;"></i>
                                        </div>
                                    }
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="card-title mb-1">@review.ProductName</h5>
                                    <p class="text-muted small mb-2">Rťf: @review.ProductReference</p>
                                    <div class="mb-2">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= review.Rating)
                                            {
                                                <i class="bi bi-star-fill text-warning"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-star text-muted"></i>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                            
                            <p class="mb-3">@review.Comment</p>
                            
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">@review.DateReview.ToString("dd/MM/yyyy")</small>
                                <button type="button" class="btn btn-sm btn-outline-danger delete-review" 
                                        data-review-id="@review.IdReview">
                                    <i class="bi bi-trash"></i> Supprimer
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-chat-left-text" style="font-size: 4rem; color: #ccc;"></i>
            <h3 class="mt-3">Aucun avis pour le moment</h3>
            <p class="text-muted">Vous n'avez pas encore laissť d'avis sur vos achats.</p>
            <a asp-action="MyOrders" class="btn btn-primary mt-3">
                <i class="bi bi-bag-check"></i> Voir mes commandes
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Delete review
            $('.delete-review').click(function() {
                var reviewId = $(this).data('review-id');
                
                if (confirm(' tes-vous sŻr de vouloir supprimer cet avis ?')) {
                    $.post('@Url.Action("DeleteReview", "Client")', { reviewId: reviewId })
                        .done(function(response) {
                            if (response.success) {
                                location.reload();
                            } else {
                                alert(response.message);
                            }
                        })
                        .fail(function() {
                            alert('Une erreur est survenue');
                        });
                }
            });

            // Auto-dismiss alerts
            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 5000);
        });
    </script>
}
