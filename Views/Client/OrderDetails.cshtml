@model Solution_Magasin.ViewModels.OrderDetailsViewModel
@{
    ViewData["Title"] = $"Commande #{Model.IdVente}";
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Espace Client</a></li>
            <li class="breadcrumb-item"><a asp-action="MyOrders">Mes Commandes</a></li>
            <li class="breadcrumb-item active">Commande #@Model.IdVente</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">Commande #@Model.IdVente</h4>
                        <span class="badge @(Model.PaymentStatus == "Payé" ? "bg-success" : "bg-warning") fs-6">
                            @Model.PaymentStatus
                        </span>
                    </div>
                    <small class="text-muted">Passée le @Model.DateVente?.ToString("dd MMMM yyyy ŕ HH:mm")</small>
                </div>
                <div class="card-body">
                    <h6 class="mb-3">Articles commandés</h6>
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Produit</th>
                                    <th>Prix unitaire</th>
                                    <th>Quantité</th>
                                    <th class="text-end">Total</th>
                                    <th class="text-center no-print">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                @if (!string.IsNullOrEmpty(item.ImagePath))
                                                {
                                                    <img src="@item.ImagePath" alt="@item.ProductName" class="me-3 rounded" style="width: 60px; height: 60px; object-fit: cover;">
                                                }
                                                else
                                                {
                                                    <div class="bg-secondary text-white d-flex align-items-center justify-content-center me-3 rounded" style="width: 60px; height: 60px;">
                                                        <i class="bi bi-image"></i>
                                                    </div>
                                                }
                                                <div>
                                                    <strong>@item.ProductName</strong><br>
                                                    <small class="text-muted">Réf: @item.ProductReference</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="align-middle">@item.UnitPrice.ToString("N2") DH</td>
                                        <td class="align-middle">@item.Quantity</td>
                                        <td class="align-middle text-end">
                                            <strong>@item.TotalPrice.ToString("N2") DH</strong>
                                        </td>
                                        <td class="align-middle text-center no-print">
                                            <div class="btn-group btn-group-sm" role="group">
                                                <button type="button" class="btn btn-outline-primary btn-review" 
                                                        data-article-id="@item.IdArticle"
                                                        data-article-name="@item.ProductName"
                                                        data-article-image="@item.ImagePath">
                                                    <i class="bi bi-star"></i> Avis
                                                </button>
                                                <a asp-action="RequestReturn" 
                                                   asp-route-orderId="@Model.IdVente" 
                                                   asp-route-articleId="@item.IdArticle"
                                                   class="btn btn-outline-warning">
                                                    <i class="bi bi-arrow-return-left"></i> Retour
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 no-print">
                <a asp-action="MyOrders" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-left"></i> Retour aux commandes
                </a>
                <button onclick="window.print()" class="btn btn-outline-secondary">
                    <i class="bi bi-printer"></i> Imprimer
                </button>
                <a asp-action="ViewInvoice" asp-route-orderId="@Model.IdVente" 
                   class="btn btn-success" target="_blank">
                    <i class="bi bi-file-earmark-pdf"></i> Télécharger la facture
                </a>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- Summary Card -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white">
                    <h6 class="mb-0">Récapitulatif</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Sous-total</span>
                        <strong>@Model.Items.Sum(i => i.TotalPrice).ToString("N2") DH</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Frais de livraison</span>
                        <strong>50.00 DH</strong>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span class="h6">Total</span>
                        <strong class="h6 text-primary">@Model.TotalAmount?.ToString("N2") DH</strong>
                    </div>
                </div>
            </div>

            <!-- Payment Info -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white">
                    <h6 class="mb-0">Informations de paiement</h6>
                </div>
                <div class="card-body">
                    <p class="mb-2">
                        <strong>Méthode:</strong><br>
                        @Model.PaymentMethod
                    </p>
                    <p class="mb-0">
                        <strong>Statut:</strong><br>
                        <span class="badge @(Model.PaymentStatus == "Payé" ? "bg-success" : "bg-warning")">
                            @Model.PaymentStatus
                        </span>
                    </p>
                </div>
            </div>

            <!-- Delivery Info -->
            @if (!string.IsNullOrEmpty(Model.ShippingAddress))
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white">
                        <h6 class="mb-0">Adresse de livraison</h6>
                    </div>
                    <div class="card-body">
                        <p class="mb-2">@Model.ShippingAddress</p>
                        @if (!string.IsNullOrEmpty(Model.Phone))
                        {
                            <p class="mb-0">
                                <i class="bi bi-telephone"></i> @Model.Phone
                            </p>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Review Modal -->
<div class="modal fade" id="reviewModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Laisser un avis</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="review-product-info" class="mb-3 p-2 bg-light rounded">
                    <div class="d-flex align-items-center">
                        <img id="review-product-image" src="" alt="" class="me-2 rounded" style="width: 50px; height: 50px; object-fit: cover;">
                        <strong id="review-product-name"></strong>
                    </div>
                </div>
                <form id="reviewForm">
                    <input type="hidden" id="review-article-id" name="IdArticle">
                    
                    <div class="mb-3">
                        <label class="form-label">Note <span class="text-danger">*</span></label>
                        <div class="rating-stars">
                            <i class="bi bi-star rating-star" data-rating="1"></i>
                            <i class="bi bi-star rating-star" data-rating="2"></i>
                            <i class="bi bi-star rating-star" data-rating="3"></i>
                            <i class="bi bi-star rating-star" data-rating="4"></i>
                            <i class="bi bi-star rating-star" data-rating="5"></i>
                        </div>
                        <input type="hidden" id="review-rating" name="Rating" value="0">
                        <div class="text-danger" id="rating-error" style="display:none;">Veuillez sélectionner une note</div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="review-comment" class="form-label">Commentaire <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="review-comment" name="Comment" rows="4" 
                                  placeholder="Partagez votre expérience avec ce produit..." required></textarea>
                        <div class="form-text">Minimum 10 caractčres, maximum 300 caractčres</div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" id="submit-review">Publier l'avis</button>
            </div>
        </div>
    </div>
</div>

<style media="print">
    nav, .btn, footer, header, .no-print { display: none !important; }
    .container { max-width: 100% !important; }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            var reviewModal = new bootstrap.Modal(document.getElementById('reviewModal'));
            
            // Open review modal
            $('.btn-review').click(function() {
                var articleId = $(this).data('article-id');
                var articleName = $(this).data('article-name');
                var articleImage = $(this).data('article-image');
                
                $('#review-article-id').val(articleId);
                $('#review-product-name').text(articleName);
                $('#review-product-image').attr('src', articleImage || '/images/placeholder.jpg');
                $('#review-rating').val(0);
                $('#review-comment').val('');
                $('.rating-star').removeClass('bi-star-fill').addClass('bi-star');
                
                reviewModal.show();
            });
            
            // Rating stars
            $('.rating-star').click(function() {
                var rating = $(this).data('rating');
                $('#review-rating').val(rating);
                $('#rating-error').hide();
                
                $('.rating-star').each(function(index) {
                    if (index < rating) {
                        $(this).removeClass('bi-star').addClass('bi-star-fill');
                    } else {
                        $(this).removeClass('bi-star-fill').addClass('bi-star');
                    }
                });
            });
            
            // Submit review
            $('#submit-review').click(function() {
                var rating = $('#review-rating').val();
                var comment = $('#review-comment').val();
                var articleId = $('#review-article-id').val();
                
                if (rating == 0) {
                    $('#rating-error').show();
                    return;
                }
                
                if (comment.length < 10) {
                    alert('Le commentaire doit contenir au moins 10 caractčres');
                    return;
                }
                
                $.post('@Url.Action("AddReview", "Client")', {
                    IdArticle: articleId,
                    Rating: rating,
                    Comment: comment,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                })
                .done(function(response) {
                    if (response.success) {
                        reviewModal.hide();
                        alert(response.message);
                    } else {
                        alert(response.message);
                    }
                })
                .fail(function() {
                    alert('Une erreur est survenue');
                });
            });
        });
    </script>
    
    <style>
        .rating-stars {
            font-size: 2rem;
            color: #ffc107;
        }
        .rating-star {
            cursor: pointer;
            transition: all 0.2s;
        }
        .rating-star:hover {
            transform: scale(1.2);
        }
    </style>
}
