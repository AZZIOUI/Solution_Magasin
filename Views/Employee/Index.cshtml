@using Microsoft.AspNetCore.Identity
@using Solution_Magasin.Models
@using Solution_Magasin.Constants
@inject UserManager<AspNetUser> UserManager

@{
    ViewData["Title"] = "Espace EmployÈ";
    var user = await UserManager.GetUserAsync(User);
    var roles = user != null ? await UserManager.GetRolesAsync(user) : new List<string>();
    var isAdmin = roles.Contains(RoleConstants.Administrateur);
    var isResponsableAchat = roles.Contains(RoleConstants.ResponsableAchat);
    var isMagasinier = roles.Contains(RoleConstants.Magasinier);
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h1>@ViewData["Message"]</h1>
            <p class="lead">Bonjour @user?.Prenom @user?.Nom</p>
            <p>
                <strong>RÙle(s) :</strong> 
                @string.Join(", ", roles)
            </p>
        </div>
    </div>
    
    <div class="row mt-4">
        <!-- Accessible ‡ tous les employÈs -->
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Ventes</h5>
                    <p class="card-text">GÈrer les ventes</p>
                    <a asp-action="Sales" class="btn btn-primary">AccÈder</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">PrÈsences</h5>
                    <p class="card-text">Pointage des prÈsences</p>
                    <a asp-action="Presence" class="btn btn-primary">AccÈder</a>
                </div>
            </div>
        </div>
        
        @if (isAdmin || isResponsableAchat)
        {
            <!-- Accessible aux Admins et Responsables Achat -->
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Achats</h5>
                        <p class="card-text">Gestion des achats fournisseurs</p>
                        <a asp-action="Purchases" class="btn btn-warning">AccÈder</a>
                    </div>
                </div>
            </div>
        }
        
        @if (isAdmin || isMagasinier)
        {
            <!-- Accessible aux Admins et Magasiniers -->
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Stock</h5>
                        <p class="card-text">Gestion du stock</p>
                        <a asp-action="Stock" class="btn btn-warning">AccÈder</a>
                    </div>
                </div>
            </div>
        }
        
        @if (isAdmin)
        {
            <!-- Accessible uniquement aux Admins -->
            <div class="col-md-4 mb-3">
                <div class="card border-danger">
                    <div class="card-body">
                        <h5 class="card-title">Utilisateurs</h5>
                        <p class="card-text">Gestion des utilisateurs</p>
                        <a asp-action="Users" class="btn btn-danger">AccÈder</a>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4 mb-3">
                <div class="card border-danger">
                    <div class="card-body">
                        <h5 class="card-title">Rapports</h5>
                        <p class="card-text">Rapports et statistiques</p>
                        <a asp-action="Reports" class="btn btn-danger">AccÈder</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
