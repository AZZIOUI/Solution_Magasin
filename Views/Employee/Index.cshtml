@{
    ViewData["Title"] = "Espace Employé";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">@ViewData["Title"]</h1>
            <div class="alert alert-info" role="alert">
                <h4 class="alert-heading">Bienvenue dans votre espace employé !</h4>
                <p>Vous ętes connecté en tant que <strong>@User.Identity?.Name</strong></p>
                <p class="mb-0">
                    Rôle(s) : 
                    @if (User.IsInRole("Administrateur"))
                    {
                        <span class="badge bg-danger">Administrateur</span>
                    }
                    @if (User.IsInRole("ResponsableAchat"))
                    {
                        <span class="badge bg-warning">Responsable d'Achat</span>
                    }
                    @if (User.IsInRole("Magasinier"))
                    {
                        <span class="badge bg-primary">Magasinier</span>
                    }
                </p>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        @if (User.IsInRole("Administrateur") || User.IsInRole("Magasinier"))
        {
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Gestion des Stocks</h5>
                        <p class="card-text">Gérez les stocks, les articles et les notifications.</p>
                        <a asp-action="StockManagement" class="btn btn-primary">Accéder</a>
                    </div>
                </div>
            </div>
        }

        @if (User.IsInRole("Administrateur") || User.IsInRole("ResponsableAchat"))
        {
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Gestion des Achats</h5>
                        <p class="card-text">Gérez les achats auprčs des fournisseurs.</p>
                        <a asp-action="PurchaseManagement" class="btn btn-primary">Accéder</a>
                    </div>
                </div>
            </div>
        }

        @if (User.IsInRole("Administrateur"))
        {
            <div class="col-md-4 mb-3">
                <div class="card border-danger">
                    <div class="card-body">
                        <h5 class="card-title text-danger">
                            <i class="bi bi-shield-lock"></i> Administration
                        </h5>
                        <p class="card-text">Gestion des utilisateurs, employés et paramčtres systčme.</p>
                        <a asp-controller="Admin" asp-action="Index" class="btn btn-danger">Accéder</a>
                    </div>
                </div>
            </div>
        }

        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Tableau de bord</h5>
                    <p class="card-text">Consultez les statistiques et rapports.</p>
                    <a href="#" class="btn btn-primary">Voir le tableau de bord</a>
                </div>
            </div>
        </div>
    </div>
</div>
