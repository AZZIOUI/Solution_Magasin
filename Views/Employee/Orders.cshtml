@model List<Solution_Magasin.ViewModels.EmployeeOrderViewModel>
@{
    ViewData["Title"] = "Gestion des Commandes";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-box-seam"></i> Gestion des Commandes</h2>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Retour au tableau de bord
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filtres -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Orders" method="get" class="row g-3">
                <div class="col-md-3">
                    <label for="status" class="form-label">Statut</label>
                    <select name="status" id="status" class="form-select">
                        <option value="">Tous les statuts</option>
                        @foreach (var status in ViewBag.Statuses)
                        {
                            <option value="@status.Value" selected="@(status.Value == ViewBag.Status)">@status.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="startDate" class="form-label">Date début</label>
                    <input type="date" name="startDate" id="startDate" class="form-control" 
                           value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-3">
                    <label for="endDate" class="form-label">Date fin</label>
                    <input type="date" name="endDate" id="endDate" class="form-control" 
                           value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="bi bi-funnel"></i> Filtrer
                    </button>
                    <a asp-action="Orders" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Réinitialiser
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Statistiques rapides -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-warning">
                <div class="card-body text-center">
                    <i class="bi bi-hourglass-split fs-1 text-warning"></i>
                    <h3 class="mt-2">@Model.Count(o => o.Status == "En traitement")</h3>
                    <p class="text-muted mb-0">En traitement</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-info">
                <div class="card-body text-center">
                    <i class="bi bi-box-seam fs-1 text-info"></i>
                    <h3 class="mt-2">@Model.Count(o => o.Status == "En préparation")</h3>
                    <p class="text-muted mb-0">En préparation</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-primary">
                <div class="card-body text-center">
                    <i class="bi bi-check-circle fs-1 text-primary"></i>
                    <h3 class="mt-2">@Model.Count(o => o.Status == "Prête")</h3>
                    <p class="text-muted mb-0">Prêtes</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-success">
                <div class="card-body text-center">
                    <i class="bi bi-truck fs-1 text-success"></i>
                    <h3 class="mt-2">@Model.Count(o => o.Status == "Expédiée" || o.Status == "Livrée")</h3>
                    <p class="text-muted mb-0">Expédiées/Livrées</p>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="ordersTable">
                        <thead>
                            <tr>
                                <th>N° Commande</th>
                                <th>Date</th>
                                <th>Client</th>
                                <th>Téléphone</th>
                                <th>Articles</th>
                                <th class="text-end">Total</th>
                                <th>Paiement</th>
                                <th>Statut</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                var statusClass = order.Status switch
                                {
                                    "En traitement" => "warning",
                                    "En préparation" => "info",
                                    "Prête" => "primary",
                                    "Expédiée" => "success",
                                    "Livrée" => "success",
                                    _ => "secondary"
                                };
                                
                                <tr>
                                    <td>
                                        <strong>#CMD-@order.IdVente.ToString("D6")</strong>
                                    </td>
                                    <td>@order.DateVente?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <div>
                                            <strong>@order.ClientName</strong>
                                        </div>
                                    </td>
                                    <td>
                                        <a href="tel:@order.ClientPhone">
                                            <i class="bi bi-telephone"></i> @order.ClientPhone
                                        </a>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@order.ItemCount article(s)</span>
                                    </td>
                                    <td class="text-end">
                                        <strong class="text-success">@order.TotalV?.ToString("N2") DH</strong>
                                    </td>
                                    <td>
                                        <span class="badge @(order.PaymentStatus == "Payé" ? "bg-success" : "bg-warning")">
                                            @order.PaymentStatus
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-@statusClass">@order.Status</span>
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="OrderDetails" asp-route-id="@order.IdVente" 
                                           class="btn btn-sm btn-outline-primary" title="Voir les détails">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
            <h3 class="mt-3">Aucune commande trouvée</h3>
            <p class="text-muted">Les commandes apparaîtront ici.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#ordersTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/fr-FR.json'
                },
                order: [[1, 'desc']], // Sort by date (newest first)
                pageLength: 25
            });

            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 5000);
        });
    </script>
}
