@model IEnumerable<EmployeePurchaseViewModel>
@{
    ViewData["Title"] = "Gestion des Achats";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2><i class="bi bi-cart-check"></i> Gestion des Achats</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Espace Employé</a></li>
                    <li class="breadcrumb-item active">Gestion des Achats</li>
                </ol>
            </nav>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="CreatePurchase" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Nouvel Achat
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filtres -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="PurchaseManagement" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Date Début</label>
                    <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Date Fin</label>
                    <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Fournisseur</label>
                    <select name="supplierId" class="form-select">
                        <option value="">Tous les fournisseurs</option>
                        @foreach (var supplier in ViewBag.Suppliers as List<SelectListItem>)
                        {
                            <option value="@supplier.Value" selected="@(ViewBag.SupplierId?.ToString() == supplier.Value)">
                                @supplier.Text
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Filtrer
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Statistiques -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Total Achats</h5>
                    <h2 class="text-primary">@Model.Count()</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Total Articles</h5>
                    <h2 class="text-success">@Model.Sum(m => m.NombreArticles)</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Montant Total</h5>
                    <h2 class="text-warning">@Model.Sum(m => m.Total ?? 0).ToString("N2") MAD</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Liste des Achats -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-table"></i> Liste des Achats</h5>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Aucun achat trouvé.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover" id="purchaseTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Date</th>
                                <th>Fournisseur</th>
                                <th>Contact</th>
                                <th>Nb Articles</th>
                                <th>Total</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var achat in Model)
                            {
                                <tr>
                                    <td><strong>#@achat.IdAchat</strong></td>
                                    <td>@achat.DateAchat?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@achat.NomFournisseur</td>
                                    <td>@achat.TelFournisseur</td>
                                    <td>
                                        <span class="badge bg-info">@achat.NombreArticles articles</span>
                                    </td>
                                    <td>
                                        <strong class="text-success">@achat.Total?.ToString("N2") MAD</strong>
                                    </td>
                                    <td>
                                        <a asp-action="PurchaseDetails" asp-route-id="@achat.IdAchat" 
                                           class="btn btn-sm btn-primary" title="Voir détails">
                                            <i class="bi bi-eye"></i> Détails
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#purchaseTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/fr-FR.json'
                },
                pageLength: 25,
                order: [[1, 'desc']]
            });
        });
    </script>
}
