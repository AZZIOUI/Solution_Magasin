@{
    ViewData["Title"] = "Bienvenue";
    var featuredProducts = ViewBag.FeaturedProducts as List<Solution_Magasin.ViewModels.ProductCardViewModel>;
    var categories = ViewBag.Categories as List<Solution_Magasin.Models.Categorie>;
}

<div class="visitor-home">
    <!-- Hero Section -->
    <section class="hero-section bg-primary text-white py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h1 class="display-4 fw-bold mb-4">Bienvenue dans notre boutique</h1>
                    <p class="lead mb-4">Découvrez nos produits de qualité avec des prix compétitifs</p>
                    <div class="d-flex gap-3">
                        <a asp-action="Catalog" class="btn btn-light btn-lg">
                            <i class="bi bi-grid"></i> Voir le catalogue
                        </a>
                        @if (!User.Identity.IsAuthenticated)
                        {
                            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg">
                                <i class="bi bi-person-plus"></i> S'inscrire
                            </a>
                        }
                    </div>
                </div>
                <div class="col-lg-6 text-center">
                    <i class="bi bi-shop" style="font-size: 10rem; opacity: 0.3;"></i>
                </div>
            </div>
        </div>
    </section>

    <!-- Categories Section -->
    @if (categories != null && categories.Any())
    {
        <section class="categories-section py-5">
            <div class="container">
                <h2 class="text-center mb-4">Nos Catégories</h2>
                <div class="row g-4">
                    @foreach (var category in categories)
                    {
                        <div class="col-md-4 col-lg-2">
                            <a asp-action="Catalog" asp-route-categoryId="@category.IdCat" class="text-decoration-none">
                                <div class="card border-0 shadow-sm hover-lift text-center h-100">
                                    <div class="card-body">
                                        <i class="bi bi-tag fs-1 text-primary mb-3"></i>
                                        <h5 class="card-title">@category.NomCat</h5>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
                <div class="text-center mt-4">
                    <a asp-action="Catalog" class="btn btn-outline-primary">
                        Voir toutes les catégories
                    </a>
                </div>
            </div>
        </section>
    }

    <!-- Featured Products Section -->
    @if (featuredProducts != null && featuredProducts.Any())
    {
        <section class="featured-products py-5 bg-light">
            <div class="container">
                <h2 class="text-center mb-4">Produits Populaires</h2>
                <div class="row g-4">
                    @foreach (var product in featuredProducts)
                    {
                        <div class="col-md-6 col-lg-3">
                            <div class="card h-100 border-0 shadow-sm hover-lift">
                                @if (!string.IsNullOrEmpty(product.ImagePath))
                                {
                                    <img src="@product.ImagePath" class="card-img-top" alt="@product.NomArt" style="height: 200px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 200px;">
                                        <i class="bi bi-image fs-1"></i>
                                    </div>
                                }
                                <div class="card-body">
                                    <span class="badge bg-primary mb-2">@product.CategoryName</span>
                                    <h5 class="card-title">@product.NomArt</h5>
                                    <p class="card-text text-muted small">@product.DesignationArt</p>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="h5 text-primary mb-0">@product.PrixUnit?.ToString("N2") DH</span>
                                        @if (product.ReviewCount > 0)
                                        {
                                            <span class="text-warning">
                                                <i class="bi bi-star-fill"></i> @product.AverageRating?.ToString("N1")
                                                <small class="text-muted">(@product.ReviewCount)</small>
                                            </span>
                                        }
                                    </div>
                                    @if (product.IsInStock)
                                    {
                                        <span class="badge bg-success">En stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Rupture de stock</span>
                                    }
                                </div>
                                <div class="card-footer bg-transparent border-0">
                                    <a asp-action="ProductDetails" asp-route-id="@product.IdArticle" class="btn btn-outline-primary w-100">
                                        <i class="bi bi-eye"></i> Voir détails
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="text-center mt-4">
                    <a asp-action="Catalog" class="btn btn-primary btn-lg">
                        Voir tous les produits
                    </a>
                </div>
            </div>
        </section>
    }

    <!-- CTA Section -->
    <section class="cta-section py-5">
        <div class="container text-center">
            <h2 class="mb-4">Pręt ŕ commencer vos achats ?</h2>
            @if (User.Identity.IsAuthenticated)
            {
                <a asp-action="Catalog" class="btn btn-primary btn-lg">
                    <i class="bi bi-bag"></i> Parcourir les produits
                </a>
            }
            else
            {
                <div>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg me-2">
                        <i class="bi bi-person-plus"></i> Créer un compte
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-lg">
                        <i class="bi bi-box-arrow-in-right"></i> Se connecter
                    </a>
                </div>
            }
        </div>
    </section>
</div>

<style>
    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
</style>
